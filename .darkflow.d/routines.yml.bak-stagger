# .darkflow.d/routines.yml — auto-generated by get-config.sh from Dark Flow Web UI
# Edit routines in the Web UI Settings tab (Settings > Routine schedule).

defaults:
  model: sonnet
  engine: claude
  permission_mode: bypassPermissions

routines:
  architecture-review:
    cron: "0 2 * * 0"
    model: opus
    engine: claude
    enabled: true
  build-optimization:
    cron: "0 4 * * 0"
    model: opus
    engine: claude
    enabled: true
  claude-md-update:
    cron: "0 9 * * 1-5"
    model: sonnet
    engine: claude
    enabled: true
  coolify-check-deployment:
    cron: "0 9 * * *"
    model: sonnet
    engine: claude
    enabled: true
  coolify-check-logs:
    cron: "30 9 * * *"
    model: sonnet
    engine: claude
    enabled: true
  fix-issues:
    cron: "0 * * * *"
    model: sonnet
    engine: claude
    enabled: true
  observability-check:
    cron: "30 8 * * *"
    model: sonnet
    engine: claude
    enabled: true
  security-audit:
    cron: "0 3 * * 0"
    model: opus
    engine: claude
    enabled: true
  vulnerability-check:
    cron: "0 6 * * *"
    model: sonnet
    engine: claude
    enabled: true
